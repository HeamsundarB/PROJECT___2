<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NexGuard — AI-Driven Next-Gen Firewall</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --neon:#00d4ff;
  --neon2:#0088ff;
  --neon3:#7c3aed;
  --glow:rgba(0,212,255,0.4);
  --glow2:rgba(0,136,255,0.25);
  --glass:rgba(255,255,255,0.04);
  --glass2:rgba(255,255,255,0.08);
  --glass3:rgba(0,212,255,0.06);
  --border:rgba(0,212,255,0.18);
  --border2:rgba(255,255,255,0.08);
  --bg:#020810;
  --bg2:#030d1a;
  --text:#e8f4ff;
  --text2:rgba(232,244,255,0.6);
  --text3:rgba(232,244,255,0.35);
  --mono:'JetBrains Mono',monospace;
  --sans:'Space Grotesk',sans-serif;
  --inter:'Inter',sans-serif;
}

html{scroll-behavior:smooth;overflow-x:hidden}

body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--sans);
  min-height:100vh;
  overflow-x:hidden;
  cursor:none;
}

/* Custom cursor */
.cursor{
  position:fixed;width:12px;height:12px;
  background:var(--neon);
  border-radius:50%;
  pointer-events:none;z-index:99999;
  transition:transform 0.1s,opacity 0.2s;
  mix-blend-mode:screen;
  box-shadow:0 0 20px var(--neon),0 0 40px rgba(0,212,255,0.5);
}
.cursor-ring{
  position:fixed;width:36px;height:36px;
  border:1px solid rgba(0,212,255,0.5);
  border-radius:50%;
  pointer-events:none;z-index:99998;
  transition:transform 0.15s ease,width 0.2s,height 0.2s;
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:#010810}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--neon),var(--neon2));border-radius:2px}

/* ===== CANVAS BG ===== */
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}

/* ===== NAV ===== */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  padding:1.2rem 4rem;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(2,8,16,0.6);
  backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
  transition:all 0.3s;
}
nav.scrolled{padding:0.8rem 4rem;background:rgba(2,8,16,0.92)}

.logo{
  display:flex;align-items:center;gap:12px;
  font-weight:700;font-size:1.25rem;letter-spacing:-0.02em;
  text-decoration:none;color:var(--text);
}
.logo-icon{
  width:36px;height:36px;
  background:linear-gradient(135deg,var(--neon),var(--neon2));
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:0.85rem;font-weight:700;color:#000;
  font-family:var(--mono);
  box-shadow:0 0 20px rgba(0,212,255,0.5);
  position:relative;overflow:hidden;
}
.logo-icon::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(45deg,transparent 40%,rgba(255,255,255,0.3) 50%,transparent 60%);
  animation:logoshine 3s infinite;
}
@keyframes logoshine{0%,100%{transform:translateX(-100%)}50%{transform:translateX(200%)}}

.logo span{
  background:linear-gradient(90deg,var(--text),var(--neon));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

.nav-links{display:flex;align-items:center;gap:2rem}
.nav-links a{
  color:var(--text2);text-decoration:none;font-size:0.88rem;font-weight:500;
  letter-spacing:0.02em;transition:color 0.2s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;
  background:var(--neon);transform:scaleX(0);transform-origin:left;
  transition:transform 0.3s;
}
.nav-links a:hover{color:var(--neon)}
.nav-links a:hover::after{transform:scaleX(1)}

.btn-nav{
  padding:0.55rem 1.4rem;
  background:transparent;
  border:1px solid var(--neon);
  border-radius:8px;
  color:var(--neon);
  font-family:var(--sans);font-size:0.85rem;font-weight:600;
  cursor:pointer;transition:all 0.25s;
  position:relative;overflow:hidden;
}
.btn-nav::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,var(--neon),var(--neon2));
  opacity:0;transition:opacity 0.25s;z-index:-1;
}
.btn-nav:hover{color:#000;border-color:transparent;box-shadow:0 0 30px rgba(0,212,255,0.5)}
.btn-nav:hover::before{opacity:1}

/* ===== SECTIONS ===== */
section{position:relative;z-index:1}

/* ===== HERO ===== */
#hero{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  padding:8rem 4rem 6rem;
  text-align:center;
  overflow:hidden;
}

.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  padding:0.4rem 1.1rem;
  background:rgba(0,212,255,0.08);
  border:1px solid rgba(0,212,255,0.25);
  border-radius:999px;
  font-family:var(--mono);font-size:0.75rem;font-weight:500;
  color:var(--neon);
  letter-spacing:0.1em;text-transform:uppercase;
  margin-bottom:2.5rem;
  animation:fadeup 0.8s ease both;
}
.badge-dot{
  width:6px;height:6px;border-radius:50%;background:var(--neon);
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(0,212,255,0.6)}50%{box-shadow:0 0 0 6px rgba(0,212,255,0)}}
@keyframes fadeup{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.hero-title{
  font-family:var(--sans);
  font-size:clamp(2.8rem,6vw,5.2rem);
  font-weight:700;
  line-height:1.05;
  letter-spacing:-0.04em;
  margin-bottom:1.5rem;
  animation:fadeup 0.8s 0.1s ease both;
}
.title-line1{display:block;color:var(--text)}
.title-line2{
  display:block;
  background:linear-gradient(90deg,var(--neon) 0%,#4fc3f7 50%,var(--neon2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 30px rgba(0,212,255,0.5));
}
.title-line3{display:block;color:var(--text);opacity:0.85}

.hero-sub{
  max-width:640px;margin:0 auto 3rem;
  font-size:1.1rem;font-weight:400;
  color:var(--text2);line-height:1.7;
  animation:fadeup 0.8s 0.2s ease both;
}

.hero-actions{
  display:flex;align-items:center;justify-content:center;gap:1.2rem;
  flex-wrap:wrap;
  animation:fadeup 0.8s 0.3s ease both;
}

.btn-primary{
  padding:0.85rem 2.2rem;
  background:linear-gradient(135deg,var(--neon),var(--neon2));
  border:none;border-radius:10px;
  color:#000;font-family:var(--sans);font-size:0.95rem;font-weight:700;
  cursor:pointer;transition:all 0.25s;
  box-shadow:0 0 30px rgba(0,212,255,0.4),0 4px 24px rgba(0,212,255,0.25);
  position:relative;overflow:hidden;
  letter-spacing:-0.01em;
}
.btn-primary::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(45deg,transparent 40%,rgba(255,255,255,0.25) 50%,transparent 60%);
  animation:btnshine 3s infinite;
}
@keyframes btnshine{0%,100%{transform:translateX(-100%)}50%{transform:translateX(200%)}}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 0 50px rgba(0,212,255,0.6),0 8px 32px rgba(0,212,255,0.35)}

.btn-ghost{
  padding:0.85rem 2.2rem;
  background:var(--glass2);
  border:1px solid var(--border);border-radius:10px;
  color:var(--text);font-family:var(--sans);font-size:0.95rem;font-weight:500;
  cursor:pointer;transition:all 0.25s;
  backdrop-filter:blur(12px);
}
.btn-ghost:hover{background:var(--glass3);border-color:var(--neon);color:var(--neon);box-shadow:0 0 20px rgba(0,212,255,0.15)}

/* Hero orb */
.hero-orb-wrap{
  position:relative;width:clamp(300px,50vw,600px);height:clamp(300px,50vw,600px);
  margin:4rem auto 2rem;
  animation:fadeup 0.8s 0.4s ease both;
}
.hero-orb{
  width:100%;height:100%;
  border-radius:50%;
  background:radial-gradient(ellipse at 35% 35%,rgba(0,212,255,0.15) 0%,rgba(0,136,255,0.08) 40%,transparent 70%);
  border:1px solid rgba(0,212,255,0.15);
  position:relative;
  animation:orb-breathe 6s ease-in-out infinite;
  box-shadow:0 0 80px rgba(0,212,255,0.1),inset 0 0 80px rgba(0,212,255,0.05);
}
@keyframes orb-breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.03)}}
.orb-ring{
  position:absolute;inset:-20px;border-radius:50%;
  border:1px solid rgba(0,212,255,0.08);
  animation:orb-breathe 6s 0.5s ease-in-out infinite;
}
.orb-ring2{
  position:absolute;inset:-45px;border-radius:50%;
  border:1px dashed rgba(0,212,255,0.05);
  animation:spin-slow 30s linear infinite;
}
.orb-ring3{
  position:absolute;inset:-70px;border-radius:50%;
  border:1px solid rgba(0,212,255,0.04);
  animation:spin-slow 50s linear infinite reverse;
}
@keyframes spin-slow{to{transform:rotate(360deg)}}

.orb-core{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:55%;height:55%;
  border-radius:50%;
  background:radial-gradient(ellipse at 40% 35%,rgba(0,212,255,0.3),rgba(0,136,255,0.15) 50%,transparent);
  animation:orb-breathe 4s ease-in-out infinite;
  box-shadow:0 0 40px rgba(0,212,255,0.3),0 0 80px rgba(0,212,255,0.1);
}

/* Floating nodes on orb */
.orb-node{
  position:absolute;
  width:10px;height:10px;border-radius:50%;
  background:var(--neon);
  box-shadow:0 0 12px var(--neon);
}
.orb-node::after{
  content:'';position:absolute;inset:-4px;
  border-radius:50%;border:1px solid rgba(0,212,255,0.4);
}

/* Stats strip */
.stats-strip{
  display:flex;align-items:center;justify-content:center;gap:3rem;
  flex-wrap:wrap;
  margin-top:1rem;
  animation:fadeup 0.8s 0.5s ease both;
}
.stat-item{text-align:center}
.stat-num{
  font-size:1.8rem;font-weight:700;
  background:linear-gradient(135deg,var(--neon),#fff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-family:var(--inter);letter-spacing:-0.04em;
}
.stat-label{font-size:0.75rem;color:var(--text3);letter-spacing:0.08em;text-transform:uppercase;margin-top:2px}
.stat-divider{width:1px;height:36px;background:var(--border)}

/* ===== SECTION COMMONS ===== */
.section-pad{padding:7rem 4rem}
.section-label{
  font-family:var(--mono);font-size:0.72rem;font-weight:500;
  color:var(--neon);letter-spacing:0.15em;text-transform:uppercase;
  margin-bottom:1rem;
  display:flex;align-items:center;gap:8px;
}
.section-label::before{content:'';display:block;width:24px;height:1px;background:var(--neon)}
.section-title{
  font-size:clamp(1.8rem,3.5vw,3rem);
  font-weight:700;letter-spacing:-0.03em;line-height:1.1;
  margin-bottom:1rem;
}
.section-title .accent{
  background:linear-gradient(90deg,var(--neon),var(--neon2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.section-sub{
  font-size:1rem;color:var(--text2);line-height:1.7;
  max-width:560px;margin-bottom:3.5rem;
}

/* ===== THREAT FEED ===== */
#threat-feed{background:linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%)}
.feed-grid{
  display:grid;grid-template-columns:1fr 1.4fr;
  gap:2rem;align-items:start;
}
.threat-log{
  background:var(--glass);
  border:1px solid var(--border2);
  border-radius:16px;
  overflow:hidden;
  backdrop-filter:blur(16px);
}
.log-header{
  padding:1rem 1.25rem;
  border-bottom:1px solid var(--border2);
  display:flex;align-items:center;justify-content:space-between;
}
.log-title{font-family:var(--mono);font-size:0.75rem;color:var(--neon);letter-spacing:0.08em}
.log-live{
  display:flex;align-items:center;gap:6px;
  font-family:var(--mono);font-size:0.7rem;color:#00ff9d;
}
.live-dot{
  width:6px;height:6px;border-radius:50%;background:#00ff9d;
  animation:pulse2 1.5s infinite;
}
@keyframes pulse2{0%,100%{opacity:1}50%{opacity:0.3}}
.log-body{padding:0.5rem 0;max-height:340px;overflow:hidden}
.log-line{
  padding:0.55rem 1.25rem;
  display:flex;align-items:center;gap:12px;
  font-family:var(--mono);font-size:0.72rem;
  border-bottom:1px solid rgba(255,255,255,0.03);
  transition:background 0.2s;
  animation:logentry 0.4s ease;
}
@keyframes logentry{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
.log-line:hover{background:rgba(0,212,255,0.04)}
.log-time{color:var(--text3);min-width:52px}
.log-type{
  padding:2px 7px;border-radius:4px;font-size:0.65rem;font-weight:600;
  letter-spacing:0.05em;min-width:68px;text-align:center;
}
.type-block{background:rgba(0,212,255,0.12);color:var(--neon)}
.type-warn{background:rgba(255,170,0,0.12);color:#ffaa00}
.type-crit{background:rgba(255,60,60,0.15);color:#ff4444;animation:critblink 1s infinite}
@keyframes critblink{0%,100%{opacity:1}50%{opacity:0.5}}
.type-info{background:rgba(100,220,100,0.1);color:#64dc64}
.log-msg{color:var(--text2);flex:1}
.log-src{color:var(--text3)}

/* Threat map placeholder */
.threat-map-card{
  background:var(--glass);border:1px solid var(--border2);
  border-radius:16px;overflow:hidden;
  backdrop-filter:blur(16px);
}
.map-header{
  padding:1rem 1.25rem;border-bottom:1px solid var(--border2);
  display:flex;align-items:center;justify-content:space-between;
}
.map-title{font-family:var(--mono);font-size:0.75rem;color:var(--neon);letter-spacing:0.08em}
#threat-canvas{display:block;width:100%;height:300px;background:rgba(0,8,20,0.8)}
.map-stats{
  display:grid;grid-template-columns:repeat(3,1fr);
  border-top:1px solid var(--border2);
}
.map-stat{
  padding:1rem 1.25rem;text-align:center;
  border-right:1px solid var(--border2);
}
.map-stat:last-child{border-right:none}
.map-stat-n{font-size:1.4rem;font-weight:700;color:var(--neon);font-family:var(--inter)}
.map-stat-l{font-size:0.7rem;color:var(--text3);margin-top:2px}

/* ===== FEATURES ===== */
#features{background:var(--bg2)}
.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;
}
.feat-card{
  padding:2rem 1.75rem;
  background:var(--glass);
  border:1px solid var(--border2);
  border-radius:16px;
  backdrop-filter:blur(16px);
  position:relative;overflow:hidden;
  transition:all 0.35s cubic-bezier(0.4,0,0.2,1);
  cursor:default;
}
.feat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--neon),transparent);
  opacity:0;transition:opacity 0.35s;
}
.feat-card::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at var(--mx,50%) var(--my,50%),rgba(0,212,255,0.06) 0%,transparent 60%);
  opacity:0;transition:opacity 0.35s;
}
.feat-card:hover{
  transform:translateY(-4px);
  border-color:rgba(0,212,255,0.3);
  box-shadow:0 20px 60px rgba(0,212,255,0.1),0 0 0 1px rgba(0,212,255,0.1);
}
.feat-card:hover::before{opacity:1}
.feat-card:hover::after{opacity:1}

.feat-icon{
  width:48px;height:48px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1.25rem;
  font-size:1.25rem;
  position:relative;z-index:1;
}
.icon-blue{background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.2)}
.icon-purple{background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.25)}
.icon-green{background:rgba(0,255,157,0.08);border:1px solid rgba(0,255,157,0.2)}
.feat-title{font-size:1.05rem;font-weight:600;margin-bottom:0.6rem;letter-spacing:-0.02em;position:relative;z-index:1}
.feat-desc{font-size:0.875rem;color:var(--text2);line-height:1.65;position:relative;z-index:1}

.feat-card.wide{grid-column:span 2}
.feat-card.wide .feat-inner{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center}

/* ===== ARCHITECTURE ===== */
#architecture{background:var(--bg)}
.arch-canvas-wrap{
  position:relative;
  border-radius:20px;overflow:hidden;
  border:1px solid var(--border);
  background:rgba(0,5,15,0.8);
  backdrop-filter:blur(24px);
}
#arch-canvas{display:block;width:100%;height:500px}

/* ===== ZERO TRUST ===== */
#zero-trust{background:var(--bg2)}
.zt-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.zt-visual{
  position:relative;aspect-ratio:1;max-width:480px;
}
.zt-ring-wrap{
  position:relative;width:100%;padding-top:100%;
}
.zt-ring-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.zt-ring{
  position:absolute;border-radius:50%;border:1px solid rgba(0,212,255,0.12);
}
.zt-center{
  width:90px;height:90px;border-radius:50%;
  background:linear-gradient(135deg,rgba(0,212,255,0.2),rgba(0,136,255,0.1));
  border:1px solid rgba(0,212,255,0.4);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:0.65rem;color:var(--neon);
  text-align:center;letter-spacing:0.05em;
  z-index:10;position:relative;
  box-shadow:0 0 40px rgba(0,212,255,0.3);
}
.zt-node{
  position:absolute;
  width:56px;height:56px;border-radius:12px;
  background:rgba(0,212,255,0.06);
  border:1px solid rgba(0,212,255,0.2);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:4px;z-index:5;
  backdrop-filter:blur(8px);
  transition:all 0.3s;
}
.zt-node:hover{background:rgba(0,212,255,0.12);box-shadow:0 0 20px rgba(0,212,255,0.2);transform:scale(1.05)}
.zt-node-icon{font-size:1.1rem}
.zt-node-label{font-family:var(--mono);font-size:0.55rem;color:var(--text3);text-align:center}

.zt-principles{display:flex;flex-direction:column;gap:1.2rem;margin-top:2.5rem}
.zt-principle{
  display:flex;gap:1rem;align-items:flex-start;
  padding:1.2rem;
  background:var(--glass);
  border:1px solid var(--border2);
  border-radius:12px;
  backdrop-filter:blur(8px);
  transition:all 0.25s;
}
.zt-principle:hover{border-color:rgba(0,212,255,0.25);background:rgba(0,212,255,0.04)}
.zt-principle-num{
  font-family:var(--mono);font-size:0.75rem;
  color:var(--neon);opacity:0.7;
  min-width:24px;margin-top:2px;
}
.zt-principle-title{font-size:0.9rem;font-weight:600;margin-bottom:0.3rem}
.zt-principle-desc{font-size:0.82rem;color:var(--text2);line-height:1.55}

/* ===== AI ENGINE ===== */
#ai-engine{background:var(--bg)}
.ai-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:3rem;align-items:center}
.ai-metrics{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.ai-metric{
  padding:1.5rem;
  background:var(--glass);
  border:1px solid var(--border2);
  border-radius:14px;
  backdrop-filter:blur(12px);
  transition:all 0.3s;
  position:relative;overflow:hidden;
}
.ai-metric::after{
  content:'';position:absolute;bottom:0;left:0;
  height:2px;border-radius:1px;
  background:linear-gradient(90deg,var(--neon),var(--neon2));
  transition:width 0.8s cubic-bezier(0.4,0,0.2,1);
}
.ai-metric:hover::after{opacity:0.8}
.metric-val{
  font-size:2.2rem;font-weight:700;
  font-family:var(--inter);letter-spacing:-0.04em;
  background:linear-gradient(135deg,var(--neon),#fff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.metric-unit{font-size:1rem;font-weight:400;opacity:0.7}
