<script>
// ===== CURSOR =====
const cursor=document.getElementById('cursor'),ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cursor.style.left=mx-6+'px';cursor.style.top=my-6+'px';
});
function animRing(){
  rx+=(mx-rx-18)*0.12;ry+=(my-ry-18)*0.12;
  ring.style.left=rx+'px';ring.style.top=ry+'px';
  requestAnimationFrame(animRing);
}animRing();
document.querySelectorAll('a,button').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cursor.style.transform='scale(2)';ring.style.width='50px';ring.style.height='50px'});
  el.addEventListener('mouseleave',()=>{cursor.style.transform='scale(1)';ring.style.width='36px';ring.style.height='36px'});
});

// ===== NAV SCROLL =====
window.addEventListener('scroll',()=>{
  document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>60);
});

// ===== PARTICLE BG =====
const bgC=document.getElementById('bg-canvas'),bgX=bgC.getContext('2d');
let W,H,particles=[];
function resizeBg(){W=bgC.width=window.innerWidth;H=bgC.height=window.innerHeight}
resizeBg();window.addEventListener('resize',resizeBg);
class Particle{
  constructor(){this.reset()}
  reset(){
    this.x=Math.random()*W;this.y=Math.random()*H;
    this.vx=(Math.random()-0.5)*0.3;this.vy=(Math.random()-0.5)*0.3;
    this.r=Math.random()*1.2+0.3;this.a=Math.random()*0.4+0.1;
    this.pulse=Math.random()*Math.PI*2;
  }
  draw(){
    this.pulse+=0.01;
    const a=this.a*(0.6+0.4*Math.sin(this.pulse));
    bgX.beginPath();bgX.arc(this.x,this.y,this.r,0,Math.PI*2);
    bgX.fillStyle=`rgba(0,212,255,${a})`;bgX.fill();
    this.x+=this.vx;this.y+=this.vy;
    if(this.x<0||this.x>W||this.y<0||this.y>H)this.reset();
  }
}
for(let i=0;i<120;i++)particles.push(new Particle());
// Draw connections
function drawConnections(){
  for(let i=0;i<particles.length;i++){
    for(let j=i+1;j<particles.length;j++){
      const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y;
      const d=Math.sqrt(dx*dx+dy*dy);
      if(d<120){
        bgX.beginPath();
        bgX.moveTo(particles[i].x,particles[i].y);
        bgX.lineTo(particles[j].x,particles[j].y);
        bgX.strokeStyle=`rgba(0,212,255,${(1-d/120)*0.08})`;
        bgX.lineWidth=0.5;bgX.stroke();
      }
    }
  }
}
function animBg(){
  bgX.clearRect(0,0,W,H);
  drawConnections();
  particles.forEach(p=>p.draw());
  requestAnimationFrame(animBg);
}animBg();

// ===== COUNTER ANIMATION =====
let threatened=18247;
setInterval(()=>{
  threatened+=Math.floor(Math.random()*7)+1;
  document.getElementById('cnt-threats').textContent=threatened.toLocaleString();
},800);
let liveEv=0,blockedToday=142394;
setInterval(()=>{
  liveEv=Math.floor(Math.random()*850)+120;
  blockedToday+=Math.floor(Math.random()*12);
  document.getElementById('cnt-live').textContent=liveEv.toLocaleString();
  document.getElementById('cnt-blocked').textContent=blockedToday.toLocaleString();
},1200);

// ===== THREAT LOG =====
const logTypes=[
  {cls:'type-block',label:'BLOCK'},
  {cls:'type-warn',label:'WARN'},
  {cls:'type-crit',label:'CRIT'},
  {cls:'type-info',label:'ALLOW'}
];
const logMsgs=[
  ['SQL injection attempt detected','194.165.2.18'],
  ['Port scan from unknown host','45.83.64.220'],
  ['DDoS pattern recognized','103.21.244.0'],
  ['Brute-force SSH blocked','176.32.103.205'],
  ['Anomalous data exfil attempt','192.0.2.88'],
  ['Zero-day payload signature','198.51.100.4'],
  ['Lateral movement detected','10.0.4.22'],
  ['C2 beacon blocked','185.220.101.0'],
  ['Ransomware fingerprint match','91.108.4.150'],
  ['Policy allow — verified user','10.0.1.45'],
  ['TLS fingerprint mismatch','172.217.0.100'],
  ['Crypto mining traffic halted','104.21.24.100'],
];
function getTime(){const n=new Date();return n.getHours().toString().padStart(2,'0')+':'+n.getMinutes().toString().padStart(2,'0')+':'+n.getSeconds().toString().padStart(2,'0')}
function addLog(){
  const lb=document.getElementById('log-body');
  if(!lb)return;
  const t=logTypes[Math.floor(Math.random()*logTypes.length)];
  const m=logMsgs[Math.floor(Math.random()*logMsgs.length)];
  const line=document.createElement('div');line.className='log-line';
  line.innerHTML=`<span class="log-time">${getTime()}</span><span class="log-type ${t.cls}">${t.label}</span><span class="log-msg">${m[0]}</span><span class="log-src">${m[1]}</span>`;
  lb.insertBefore(line,lb.firstChild);
  if(lb.children.length>18)lb.removeChild(lb.lastChild);
}
setInterval(addLog,600);
for(let i=0;i<14;i++)addLog();

// ===== THREAT MAP CANVAS =====
const tc=document.getElementById('threat-canvas');
const tx=tc.getContext('2d');
tc.width=tc.offsetWidth||700;tc.height=300;
window.addEventListener('resize',()=>{tc.width=tc.offsetParent?.offsetWidth||700});
const dots=[];
function randomDot(){
  return{
    x:Math.random()*tc.width,y:Math.random()*tc.height,
    tx:Math.random()*tc.width,ty:Math.random()*tc.height,
    progress:0,speed:Math.random()*0.015+0.005,
    color:Math.random()>0.7?'#ff4444':'#00d4ff',
    size:Math.random()*2+1
  };
}
for(let i=0;i<35;i++)dots.push(randomDot());
function drawMap(){
  tx.clearRect(0,0,tc.width,tc.height);
  // Grid
  tx.strokeStyle='rgba(0,212,255,0.05)';tx.lineWidth=1;
  for(let x=0;x<tc.width;x+=50){tx.beginPath();tx.moveTo(x,0);tx.lineTo(x,tc.height);tx.stroke()}
  for(let y=0;y<tc.height;y+=50){tx.beginPath();tx.moveTo(0,y);tx.lineTo(tc.width,y);tx.stroke()}
  // Static hotspots
  [[0.2,0.3],[0.5,0.4],[0.7,0.5],[0.15,0.7],[0.85,0.3],[0.6,0.2],[0.35,0.6]].forEach(([rx,ry])=>{
    const cx=rx*tc.width,cy=ry*tc.height;
    const r=tc.width/600;
    [20,14,8].forEach((rad,i)=>{
      tx.beginPath();tx.arc(cx,cy,rad*r,0,Math.PI*2);
      tx.strokeStyle=`rgba(0,212,255,${0.06+i*0.04})`;tx.lineWidth=1;tx.stroke();
    });
    tx.beginPath();tx.arc(cx,cy,4,0,Math.PI*2);
    tx.fillStyle='rgba(0,212,255,0.6)';tx.fill();
    tx.beginPath();tx.arc(cx,cy,7,0,Math.PI*2);
    tx.fillStyle='rgba(0,212,255,0.15)';tx.fill();
  });
  // Animated threat lines
  dots.forEach(d=>{
    d.progress+=d.speed;
    if(d.progress>=1){Object.assign(d,randomDot());d.progress=0;return}
    const cx=d.x+(d.tx-d.x)*d.progress,cy=d.y+(d.ty-d.y)*d.progress;
    tx.beginPath();tx.moveTo(d.x,d.y);tx.lineTo(cx,cy);
    tx.strokeStyle=d.progress<0.5?`rgba(255,68,68,${d.progress*0.6})`:`rgba(0,212,255,${(1-d.progress)*0.6})`;
    tx.lineWidth=0.8;tx.stroke();
    tx.beginPath();tx.arc(cx,cy,d.size,0,Math.PI*2);
    tx.fillStyle=d.color;tx.globalAlpha=1-d.progress*0.6;tx.fill();tx.globalAlpha=1;
  });
  requestAnimationFrame(drawMap);
}drawMap();

// ===== FEAT CARD TILT =====
function tiltCard(el,e){
  const r=el.getBoundingClientRect();
  const x=((e.clientX-r.left)/r.width)*100;
  const y=((e.clientY-r.top)/r.height)*100;
  el.style.setProperty('--mx',x+'%');el.style.setProperty('--my',y+'%');
  el.style.transform=`translateY(-4px) rotateX(${(y/r.height-0.5)*4}deg) rotateY(${(x/r.width-0.5)*4}deg)`;
}
document.querySelectorAll('.feat-card').forEach(c=>{
  c.addEventListener('mouseleave',()=>{c.style.transform=''});
});

// ===== ZT EVAL BARS =====
const ztEval=document.getElementById('zt-eval-bars');
if(ztEval){
  const items=[
    {label:'Identity Verification',v:98},
    {label:'Device Posture',v:91},
    {label:'Risk Score',v:87},
    {label:'Access Grant',v:100},
  ];
  ztEval.innerHTML=items.map(i=>`
    <div style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:0.72rem;color:var(--text2)">${i.label}</span>
        <span style="font-family:var(--mono);font-size:0.68rem;color:var(--neon)">${i.v}%</span>
      </div>
      <div style="height:3px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden">
        <div style="width:${i.v}%;height:100%;background:linear-gradient(90deg,var(--neon),var(--neon2));border-radius:2px;box-shadow:0 0 6px rgba(0,212,255,0.4)"></div>
      </div>
    </div>
  `).join('');
}

// ===== SPARKLINE =====
const spark=document.getElementById('sparkline');
if(spark){
  const sx=spark.getContext('2d');
  spark.width=spark.offsetWidth||380;spark.height=120;
  let spData=Array.from({length:60},()=>Math.floor(Math.random()*80)+20);
  function drawSpark(){
    const w=spark.width,h=spark.height;
    sx.clearRect(0,0,w,h);
    const max=100,step=w/(spData.length-1);
    // Gradient fill
    const grad=sx.createLinearGradient(0,0,0,h);
    grad.addColorStop(0,'rgba(0,212,255,0.25)');
    grad.addColorStop(1,'rgba(0,212,255,0)');
    sx.beginPath();sx.moveTo(0,h);
    spData.forEach((v,i)=>{
      const x=i*step,y=h-((v/max)*h*0.85)-4;
      i===0?sx.lineTo(x,y):sx.lineTo(x,y);
    });
    sx.lineTo((spData.length-1)*step,h);sx.closePath();
    sx.fillStyle=grad;sx.fill();
    // Line
    sx.beginPath();
    spData.forEach((v,i)=>{
      const x=i*step,y=h-((v/max)*h*0.85)-4;
      i===0?sx.moveTo(x,y):sx.lineTo(x,y);
    });
    sx.strokeStyle='rgba(0,212,255,0.9)';sx.lineWidth=1.5;
    sx.lineJoin='round';sx.stroke();
    // Latest dot
    const lx=(spData.length-1)*step,ly=h-((spData[spData.length-1]/max)*h*0.85)-4;
    sx.beginPath();sx.arc(lx,ly,3,0,Math.PI*2);
    sx.fillStyle='#00d4ff';sx.fill();
    sx.beginPath();sx.arc(lx,ly,6,0,Math.PI*2);
    sx.fillStyle='rgba(0,212,255,0.25)';sx.fill();
  }
  drawSpark();
  setInterval(()=>{
    spData.push(Math.floor(Math.random()*80)+20);
    spData.shift();
    drawSpark();
  },1000);
}

// ===== BLOCKCHAIN FLOW =====
const chain=document.getElementById('chain-flow');
if(chain){
  const blocks=[
    {n:'#1024',hash:'3a7f...d1c9',data:'DPI Event',status:'VERIFIED'},
    {n:'#1025',hash:'8b2e...4fa1',data:'ZT Policy',status:'VERIFIED'},
    {n:'#1026',hash:'c19d...7e3b',data:'Auth Log',status:'VERIFIED'},
    {n:'#1027',hash:'5f84...2a0c',data:'Alert: CRIT',status:'VERIFIED'},
    {n:'#1028',hash:'2d63...9b5e',data:'Scan Block',status:'PENDING'},
  ];
  chain.innerHTML=blocks.map((b,i)=>`
    <div class="block-node">
      <div class="block-num">BLOCK ${b.n}</div>
      <div class="block-hash">${b.hash}</div>
      <div class="block-data">${b.data}</div>
      <div class="block-status">${b.status}</div>
    </div>
    ${i<blocks.length-1?'<div class="chain-arrow">→</div>':''}
  `).join('');
}

// ===== SCROLL REVEAL =====
const revObs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting)e.target.classList.add('visible');
  });
},{threshold:0.12});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el=>revObs.observe(el));

// ===== METRIC BARS ANIMATE ON SCROLL =====
const metObs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelector('.metric-fill')?.style.setProperty('width',e.target.querySelector('.metric-fill').style.width);
    }
  });
},{threshold:0.3});
document.querySelectorAll('.ai-metric').forEach(el=>metObs.observe(el));

// ===== ORB PARALLAX =====
document.addEventListener('mousemove',e=>{
  const orb=document.getElementById('orb-wrap');
  if(!orb)return;
  const rx=(e.clientX/window.innerWidth-0.5)*10;
  const ry=(e.clientY/window.innerHeight-0.5)*10;
  orb.style.transform=`rotateX(${-ry}deg) rotateY(${rx}deg)`;
});
</script>
